apiVersion: operator.tigera.io/v1
kind: Installation
metadata:
  name: default

spec:
  calicoNetwork:
    bgp: Disabled
    ipPools:
      - cidr: {{ pod_network_cidr }}
        encapsulation: {{ calico_encapsulation_mode }}
        natOutgoing: {{ calico_nat_outgoing }}
        nodeSelector: "{{ calico_node_selector }}"
    nodeAddressAutodetectionV4:
      # The QEMU socket network has no VirtualBox host-only gateway. Reaching
      # the control-plane address selects the dedicated cluster NIC on each node.
      canReach: 192.168.56.11
      firstFound: false
